{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep, all
 ;; .cljc → portable to JVM / SCI / ClojureScript / GraalVM). The PQC primitives
 ;; (ML-KEM-768 / ML-DSA-65 / SLH-DSA) are provided on the JVM by BouncyCastle via
 ;; JCA; Ed25519 + AES-256-GCM come from the JDK. CLJS/WASM uses the kotoba-crypto
 ;; Rust provider instead (see src/kagi/crypto.cljc :: Provider seam).
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../langgraph"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../langchain"}}}
  ;; clojure -M:dev:run  → drive the demo ops through one VaultActor
  :run {:main-opts ["-m" "kagi.sim"]}
  ;; clojure -M:dev:cli <cmd>  → op 相当の CLI(vault は ./.kagi)。bin/kagi も参照。
  :cli {:main-opts ["-m" "kagi.cli"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis — clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
